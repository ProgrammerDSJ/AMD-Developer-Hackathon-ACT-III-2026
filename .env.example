# Environment Variables — HybridRouter
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Fireworks AI ─────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── Fireworks Model Tiers ────────────────────────────────────────────────────
TIER1_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
TIER2_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
TIER3_MODEL=accounts/fireworks/models/deepseek-r1

# ── Local Inference (Ollama) ──────────────────────────────────────────────────
LOCAL_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ── Feature Extraction LLM (sub-0.6B) ────────────────────────────────────────
FEATURE_LLM=qwen2.5:0.5b

# ── Router Confidence Thresholds (tuned during training) ─────────────────────
ROUTER_THRESHOLD_LOCAL=0.80
ROUTER_THRESHOLD_TIER1=0.65
ROUTER_THRESHOLD_TIER2=0.45
